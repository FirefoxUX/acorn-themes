{
  "manifest_version": 3,
  "name": "Flare",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "nova-flare@mozilla.org"
    }
  },
  "theme": {
    "colors": {
      "frame": "#F7EFF3",
      "frame_inactive": "#E3DBDF",
      "toolbar": "#FFFFFF",
      "toolbar_text": "#1E111B",
      "icons": "#5F1854",
      "icons_attention": "#DB54BF",
      "toolbar_top_separator": "#00000000",
      "toolbar_bottom_separator": "#FFB0E2",
      "toolbar_vertical_separator": "#FFB0E2",
      "tab_selected": "#FFFFFF",
      "tab_text": "#1E111B",
      "tab_background_text": "#1E111B",
      "tab_line": "#F585D3",
      "tab_loading": "#F585D3",
      "tab_background_separator": "#00000029",
      "toolbar_field": "#FFFFFF",
      "toolbar_field_text": "#1E111B",
      "toolbar_field_border": "#00000024",
      "toolbar_field_focus": "#FFFFFF",
      "toolbar_field_text_focus": "#1E111B",
      "toolbar_field_separator": "#00000029",
      "sidebar": "#FFFFFF",
      "sidebar_text": "#1E111B",
      "sidebar_border": "#FFB0E2",
      "sidebar_highlight": "#FFD5EE",
      "button_background_hover": "#FFD5EE",
      "button_background_active": "#FFB0E2",
      "ntp_background": "#F7EFF3"
    },
    "images": {
      "additional_backgrounds": [
        {
          "linear-gradient": "135deg, #F7EFF3 0%, #FFD5EE 60%, #FFB0E2 100%"
        }
      ]
    },
    "properties": {
      "color_scheme": "light",
      "content_color_scheme": "light",
      "additional_backgrounds_alignment": [
        "center"
      ],
      "additional_backgrounds_tiling": [
        "no-repeat"
      ],
      "additional_backgrounds_size": [
        "auto"
      ]
    }
  },
  "dark_theme": {
    "colors": {
      "frame": "#1E111B",
      "frame_inactive": "#10050E",
      "toolbar": "#1D1B1F",
      "toolbar_text": "#F7EFF3",
      "icons": "#F7EFF3",
      "icons_attention": "#FFB0E2",
      "toolbar_bottom_separator": "#3C1334",
      "toolbar_vertical_separator": "#3C1334",
      "tab_selected": "#1D1B1F",
      "tab_text": "#F7EFF3",
      "tab_background_text": "#F7EFF3",
      "tab_line": "#882078",
      "tab_loading": "#882078",
      "toolbar_field": "#1D1B1F",
      "toolbar_field_text": "#F7EFF3",
      "toolbar_field_border": "#3F3E42",
      "toolbar_field_focus": "#272429",
      "toolbar_field_text_focus": "#F7EFF3",
      "sidebar": "#1D1B1F",
      "sidebar_text": "#F7EFF3",
      "sidebar_border": "#3C1334",
      "sidebar_highlight": "#882078",
      "button_background_hover": "#882078",
      "button_background_active": "#B32E9F",
      "ntp_background": "#1E111B"
    },
    "images": {
      "additional_backgrounds": [
        {
          "linear-gradient": "135deg, #5F1854 0%, #3C1334 60%, #1E111B 100%"
        }
      ]
    },
    "properties": {
      "color_scheme": "dark",
      "content_color_scheme": "dark",
      "additional_backgrounds_alignment": [
        "center"
      ],
      "additional_backgrounds_tiling": [
        "no-repeat"
      ],
      "additional_backgrounds_size": [
        "auto"
      ]
    }
  }
}
