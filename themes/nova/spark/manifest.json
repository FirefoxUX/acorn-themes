{
  "manifest_version": 3,
  "name": "Spark",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "nova-spark@mozilla.org"
    }
  },
  "theme": {
    "colors": {
      "frame": "#F8F0EC",
      "frame_inactive": "#E4DCD8",
      "toolbar": "#FFFFFF",
      "toolbar_text": "#250E0B",
      "icons": "#701C07",
      "icons_attention": "#F4682C",
      "toolbar_top_separator": "#00000000",
      "toolbar_bottom_separator": "#FEBD99",
      "toolbar_vertical_separator": "#FEBD99",
      "tab_selected": "#FFFFFF",
      "tab_text": "#250E0B",
      "tab_background_text": "#250E0B",
      "tab_line": "#FF9565",
      "tab_loading": "#FF9565",
      "tab_background_separator": "#00000029",
      "toolbar_field": "#FFFFFF",
      "toolbar_field_text": "#250E0B",
      "toolbar_field_border": "#00000024",
      "toolbar_field_focus": "#FFFFFF",
      "toolbar_field_text_focus": "#250E0B",
      "toolbar_field_separator": "#00000029",
      "sidebar": "#FFFFFF",
      "sidebar_text": "#250E0B",
      "sidebar_border": "#FEBD99",
      "sidebar_highlight": "#FFDBC5",
      "button_background_hover": "#FFDBC5",
      "button_background_active": "#FEBD99",
      "ntp_background": "#F8F0EC"
    },
    "images": {
      "additional_backgrounds": [
        {
          "linear-gradient": "135deg, #F8F0EC 0%, #FFDBC5 60%, #FEBD99 100%"
        }
      ]
    },
    "properties": {
      "additional_backgrounds_alignment": [
        "center"
      ],
      "additional_backgrounds_tiling": [
        "no-repeat"
      ],
      "additional_backgrounds_size": [
        "auto"
      ]
    }
  },
  "dark_theme": {
    "colors": {
      "frame": "#250E0B",
      "frame_inactive": "#160302",
      "toolbar": "#1D1B1F",
      "toolbar_text": "#F8F0EC",
      "icons": "#F8F0EC",
      "icons_attention": "#F4682C",
      "toolbar_bottom_separator": "#461209",
      "toolbar_vertical_separator": "#461209",
      "tab_selected": "#1D1B1F",
      "tab_text": "#F8F0EC",
      "tab_background_text": "#F8F0EC",
      "tab_line": "#9C2C05",
      "tab_loading": "#9C2C05",
      "toolbar_field": "#1D1B1F",
      "toolbar_field_text": "#F8F0EC",
      "toolbar_field_border": "#3F3E42",
      "toolbar_field_focus": "#272429",
      "toolbar_field_text_focus": "#F8F0EC",
      "sidebar": "#1D1B1F",
      "sidebar_text": "#F8F0EC",
      "sidebar_border": "#461209",
      "sidebar_highlight": "#9C2C05",
      "button_background_hover": "#9C2C05",
      "button_background_active": "#CD4208",
      "ntp_background": "#250E0B"
    },
    "images": {
      "additional_backgrounds": [
        {
          "linear-gradient": "135deg, #701C07 0%, #461209 60%, #250E0B 100%"
        }
      ]
    },
    "properties": {
      "additional_backgrounds_alignment": [
        "center"
      ],
      "additional_backgrounds_tiling": [
        "no-repeat"
      ],
      "additional_backgrounds_size": [
        "auto"
      ]
    }
  }
}
